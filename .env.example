# AI FEAST ENGINE - CONFIGURATION

# Supabase (Required for Database & Auth)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-DO-NOT-EXPOSE

# Gemini AI (Required for Summaries & Translations)
GEMINI_API_KEY=your-google-ai-api-key

# Stripe (Required for Monetization)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# Server Config
PORT=3000
NODE_ENV=development

# Rate Limiting & Performance
GLOBAL_RATE_LIMIT=100
MAX_CONCURRENT_POSTS=5
BATCH_DELAY_MS=2000
